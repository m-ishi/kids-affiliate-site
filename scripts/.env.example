# ============================================================
# Kids Gear Lab — Environment Variables Template
# ============================================================
# 使用方法:
# 1. このファイルをコピーして .env を作成
# 2. 各APIキーを実際の値に置き換え
# 3. スクリプト実行前に source .env または export で設定
# ============================================================

# ============================================================
# 1. API Keys
# ============================================================

# Brave Search API (必須)
# 取得先: https://brave.com/search/api/
BRAVE_API_KEY="your_brave_api_key_here"

# Google Gemini API (必須)
# 取得先: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# ============================================================
# 2. サイト設定
# ============================================================

# Amazonアソシエイトタグ (必須)
# kidsgoodslab-22 は固定値（site-config.jsonと一致）
AMAZON_TAG="kidsgoodslab-22"

# サイト基本情報 (site-config.jsonから自動読み込み)
SITE_NAME="キッズグッズラボ"
SITE_NAME_EN="Kids Gear Lab"
SITE_URL="https://kidsgoodslab.com"
SITE_DESCRIPTION="子供用品の実用的なレビューサイト。2児のパパ目線での商品比較・選び方ガイド。"

# ============================================================
# 3. Telegram通知設定 (オプション)
# ============================================================

# Telegram Bot Token (通知機能を使用する場合)
# 取得先: @BotFather でBotを作成
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# Telegram Chat ID (通知先)
# 取得方法: @userinfobot にメッセージを送信
TELEGRAM_CHAT_ID="your_telegram_chat_id_here"

# ============================================================
# 4. 生成設定
# ============================================================

# デフォルト生成記事数
DEFAULT_ARTICLE_COUNT="5"

# デフォルト生成トピック数
DEFAULT_TOPIC_COUNT="30"

# レート制限遅延 (ミリ秒)
RATE_LIMIT_DELAY_MS="3000"

# 最大リトライ回数
MAX_RETRY_COUNT="3"

# ============================================================
# 5. ディレクトリ設定
# ============================================================

# 下書きディレクトリ
DRAFTS_DIR="../drafts"

# 公開記事ディレクトリ
ARTICLES_DIR="../articles"

# 履歴ファイル
HISTORY_FILE="history.json"

# トピックファイル
TOPICS_FILE="topics.mjs"

# ============================================================
# 6. 品質管理設定
# ============================================================

# QAチェック合格閾値 (最大許容問題数)
QA_MAX_ISSUES="3"

# 最小文字数要件
MIN_WORD_COUNT="1500"

# 最小アフィリエイトリンク数
MIN_AFFILIATE_LINKS="3"

# ============================================================
# 環境変数設定例 (bash/zsh)
# ============================================================
# export BRAVE_API_KEY="your_key"
# export GEMINI_API_KEY="your_key"
# source .env